{
  "name": "deaxner/decision-engine-api",
  "description": "Symfony API for the real-time decision platform.",
  "type": "project",
  "license": "proprietary",
  "require": {
    "php": "^8.4",
    "ext-pdo_pgsql": "*",
    "symfony/framework-bundle": "^7.4",
    "symfony/runtime": "^7.4",
    "doctrine/orm": "^3.0",
    "doctrine/doctrine-bundle": "^2.12",
    "doctrine/doctrine-migrations-bundle": "^3.3",
    "symfony/validator": "^7.4",
    "symfony/security-bundle": "^7.4",
    "symfony/messenger": "^7.4",
    "symfony/password-hasher": "^7.4",
    "symfony/serializer": "^7.4",
    "symfony/property-access": "^7.4",
    "symfony/yaml": "^7.4",
    "symfony/dotenv": "^7.4"
  },
  "autoload": {
    "psr-4": {
      "App\\": "src/"
    }
  },
  "autoload-dev": {
    "psr-4": {
      "App\\Tests\\": "tests/"
    }
  },
  "scripts": {
    "test": "php vendor/bin/phpunit",
    "test:db:up": "docker compose -f docker-compose.test.yaml up -d",
    "test:db:down": "docker compose -f docker-compose.test.yaml down -v"
  },
  "config": {
    "allow-plugins": {
      "symfony/runtime": true
    }
  },
  "require-dev": {
    "symfony/test-pack": "^1.2"
  }
}
